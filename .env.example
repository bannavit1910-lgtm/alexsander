# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงของคุณ (ห้าม commit .env ขึ้น git)

PORT=3000
SESSION_SECRET=เปลี่ยนเป็นข้อความสุ่มยาวๆของคุณเอง

# ==== TrueMoney Wallet Top-up (รับซองอั่งเปาอัตโนมัติ) ====
# TRUEMONEY_PHONE = เบอร์ TrueMoney Wallet ของ "ร้านคุณเอง" ที่จะใช้รับเงินจากซองอั่งเปาลูกค้า
# ห้าม commit เบอร์จริงขึ้น git — ใส่ในไฟล์ .env (ที่ .gitignore ไว้แล้ว) เท่านั้น อย่าใส่ในโค้ด
TRUEMONEY_PHONE=0810515287

# สำรองไว้เผื่อย้ายไปใช้ผู้ให้บริการที่มี partner API เป็นทางการในอนาคต (ยังไม่ได้ใช้งานในโค้ดปัจจุบัน)
TRUEMONEY_API_KEY=
TRUEMONEY_MERCHANT_ID=
TOPUP_WEBHOOK_SECRET=

# ==== Discord Webhook (แจ้งเตือน real-time) ====
DISCORD_WEBHOOK_URL=
